# If Homebrew is installed
# According to Post-installation steps on https://docs.brew.sh/Installation
# Change path to brew if necessary
eval "$(/opt/homebrew/bin/brew shellenv)"

# For homebrew completions
# According to https://docs.brew.sh/Shell-Completion
autoload -Uz compinit
compinit

# If Starship zsh is installed
# Installation steps:
#   brew install starship
#   mkdir -p ~/.config/
#   touch ~/.config/starship.toml
#   starship preset pure-preset -o ~/.config/starship.toml
#   brew install font-fira-code-nerd-font
#
# Then change the terminal's font to FiraCode Nerd Font Light
# and enable the following line
eval "$(starship init zsh)"

# Aliases
alias ll='ls -al'

# 1Password SSH Agent
export SSH_AUTH_SOCK=~/Library/Group\ Containers/2BUA8C4S2C.com.1password/t/agent.sock
